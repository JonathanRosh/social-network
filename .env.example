# Copy to .env before running `docker compose up`.

POSTGRES_USER=social_network
POSTGRES_PASSWORD=change_me
POSTGRES_DB=social_network

# postgres:5432 is the service name on the docker network, not localhost.
DATABASE_URL=postgresql://social_network:change_me@postgres:5432/social_network

# Long random string. Signs the session cookie.
SESSION_SECRET=change_me_too

NODE_ENV=production
BACKEND_PORT=4000
FRONTEND_PORT=3000

# No TLS in this stack (plain HTTP on localhost). Keep false or login
# breaks. Set true only if this is deployed behind real HTTPS.
COOKIE_SECURE=false
