# For running the Prisma CLI or the test suite directly on the host,
# outside Docker (e.g. `npm test` from this folder). Points at localhost
# since that's how the postgres container's port is published to the host
# — matches the values in the root .env.example.
DATABASE_URL=postgresql://social_network:change_me@localhost:5432/social_network
SESSION_SECRET=change_me_too
PORT=4000
