generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  pending
  accepted
  declined
  cancelled
}

enum PostVisibility {
  public
  friends
  private
}

// NOTE: session storage is a separate `session` table managed entirely by
// connect-pg-simple at runtime (createTableIfMissing: true) — intentionally
// not modeled here, so Prisma never tries to migrate a table it doesn't own.

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  bio          String?
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  postsAuthored          Post[]
  commentsAuthored       Comment[]
  friendRequestsSent     Friendship[]   @relation("Requester")
  friendRequestsReceived Friendship[]   @relation("Addressee")
  conversationsAsLow     Conversation[] @relation("ConversationUserLow")
  conversationsAsHigh    Conversation[] @relation("ConversationUserHigh")
  messagesSent           Message[]

  @@map("users")
}

// Single table models the entire friendship lifecycle: a pending request,
// an accepted friendship, or a terminal declined/cancelled state.
// userLowId/userHighId are always set by the application as
// (min(requesterId, addresseeId), max(...)) so that a partial unique index
// on those two columns (see migration SQL) can guarantee — at the database
// level — that no two *active* (pending/accepted) rows ever exist for the
// same pair of users, regardless of who requested.
model Friendship {
  id           String           @id @default(uuid())
  requesterId  String           @map("requester_id")
  addresseeId  String           @map("addressee_id")
  status       FriendshipStatus @default(pending)
  userLowId    String           @map("user_low_id")
  userHighId   String           @map("user_high_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

model Post {
  id         String         @id @default(uuid())
  authorId   String         @map("author_id")
  content    String
  visibility PostVisibility @default(friends)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("comments")
}

// Bonus feature. One row per unordered friend pair, normalized the same
// way as Friendship (userLowId < userHighId, enforced by the application).
model Conversation {
  id         String   @id @default(uuid())
  userLowId  String   @map("user_low_id")
  userHighId String   @map("user_high_id")
  createdAt  DateTime @default(now()) @map("created_at")

  userLow  User      @relation("ConversationUserLow", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh User      @relation("ConversationUserHigh", fields: [userHighId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userLowId, userHighId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}
