# Copy this file to .env before running `docker compose up`.
# Nothing here needs to be a "real" secret for local/dev use, but don't commit your actual .env.

POSTGRES_USER=social_network
POSTGRES_PASSWORD=change_me
POSTGRES_DB=social_network

# Used by the backend to connect to the postgres service over the docker network.
DATABASE_URL=postgresql://social_network:change_me@postgres:5432/social_network

# Any long random string. Used to sign the session ID cookie.
SESSION_SECRET=change_me_too

NODE_ENV=production
BACKEND_PORT=4000
FRONTEND_PORT=3000
